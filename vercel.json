{
  "services": {
    "frontend": {
      "root": "frontend",
      "framework": "vite",
      "routes": [
        {
          "src": "/(pricing|products|simulations|settings|login|register)(/.*)?",
          "dest": "/index.html"
        }
      ]
    },
    "backend": {
      "root": "backend",
      "framework": "go",
      "entrypoint": "main.go"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": {
        "type": "service",
        "service": "backend"
      }
    },
    {
      "source": "/(.*)",
      "destination": {
        "type": "service",
        "service": "frontend"
      }
    }
  ]
}
